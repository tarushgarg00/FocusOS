{
  "manifest_version": 3,
  "name": "FocusOS Focus Mode",
  "version": "1.0.0",
  "description": "Block distracting sites during focus sessions",
  "permissions": ["storage", "declarativeNetRequest", "alarms"],
  "host_permissions": ["<all_urls>"],
  "background": { "service_worker": "background.js" },
  "declarative_net_request": { "rule_resources": [] },
  "externally_connectable": {
    "matches": [
      "http://localhost:*/*",
      "https://*.focusos.app/*",
      "https://focusos.app/*",
      "https://*.vercel.app/*",
      "https://*.lovable.app/*",
      "https://*.netlify.app/*"
    ]
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
